                {
                  "disabled": false,
                  "key": "key",
                  "value": "<string>",
                  "description": "(Required) The caller's Rijksstudio API key."
                },
                {
                  "disabled": false,
                  "key": "format",
                  "value": "json",
                  "description": "Response format. JSON is the default."
                },
                {
                  "disabled": false,
                  "key": "page",
                  "value": "0",
                  "description": "Result page number (0-based) for the embedded `setItems` list."
                },
                {
                  "disabled": false,
                  "key": "pageSize",
                  "value": "25",
                  "description": "Items per page for the embedded `setItems` list."
                }
              ],
              "variable": [
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<string>",
                  "key": "culture",
                  "description": "(Required) Locale for the response content (`nl` Dutch, `en` English)."
