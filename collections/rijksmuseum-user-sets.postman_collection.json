          "id": "0f9da06e-a507-4c86-9d78-6da1973d2c81",
          "name": "Get Rijksstudio User Set Details",
          "request": {
            "name": "Get Rijksstudio User Set Details",
            "description": {
              "content": "Returns the full contents of a single Rijksstudio set, including the\nowner profile, set metadata, and the ordered list of set items\n(`setItems`) linking back to Collection API objects.\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                ":culture",
                "usersets",
                ":setId"
              ],
              "host": [
                "{{baseUrl}}"
              ],
