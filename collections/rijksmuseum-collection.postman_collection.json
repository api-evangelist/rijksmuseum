    {
      "id": "13389836-cf5d-4f20-99d5-b7b0720395d8",
      "name": "Images",
      "description": {
        "content": "Deep-zoom tile pyramids for object web images.",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "1bc9cf7e-ccd3-4612-bdf7-88bc47c0e31c",
          "name": "Get Collection Object Image Tiles",
          "request": {
            "name": "Get Collection Object Image Tiles",
            "description": {
              "content": "Returns the tile-pyramid description for an object's web image. The\nresponse contains one entry per zoom level (`z0`–`z6`, where `z0` is\nthe largest resolution and `z6` is the smallest), and each level\ncarries a list of image tiles with x/y coordinates and a CDN URL.\n\nThis endpoint only supports the JSON response format.\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                ":culture",
                "collection",
                ":objectNumber",
                "tiles"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "key",
                  "value": "<string>",
                  "description": "(Required) The caller's Rijksstudio API key."
                }
              ],
              "variable": [
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<string>",
                  "key": "culture",
                  "description": "(Required) Locale for both the query semantics and the response content (`nl` Dutch, `en` English)."
                },
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<string>",
                  "key": "objectNumber",
                  "description": "(Required) Case-sensitive object identifier (e.g. `SK-C-5`)."
                }
              ]
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET",
            "auth": null
          },
          "response": [
            {
              "id": "fad60fc1-024f-468d-8a4d-8ddda896c0b6",
              "name": "Tile pyramid for the requested object's web image.",
              "originalRequest": {
                "url": {
                  "path": [
                    ":culture",
                    "collection",
                    ":objectNumber",
                    "tiles"
                  ],
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "query": [
