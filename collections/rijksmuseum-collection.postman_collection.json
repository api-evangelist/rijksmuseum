{
  "item": [
    {
      "id": "5b765cae-896c-49aa-8d59-4cef9b9dde67",
      "name": "Collection",
      "description": {
        "content": "Search and browse the Rijksmuseum collection.",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "f3f08342-15de-4713-975b-e54b52ccc49d",
          "name": "Search The Rijksmuseum Collection",
          "request": {
            "name": "Search The Rijksmuseum Collection",
            "description": {
              "content": "Returns a paginated list of objects in the Rijksmuseum collection. All\nfilter parameters mirror the museum's advanced search experience.\nPagination is capped so that `p * ps` cannot exceed 10,000 results — use\nthe [OAI-PMH harvesting API](https://data.rijksmuseum.nl/object-metadata/harvest/)\nfor full-corpus access.\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                ":culture",
                "collection"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "key",
                  "value": "<string>",
                  "description": "(Required) The caller's Rijksstudio API key."
                },
                {
                  "disabled": false,
                  "key": "format",
                  "value": "json",
                  "description": "Response format. `json` is the default; `jsonp` requires a `callback` parameter; `xml` is also offered."
                },
                {
                  "disabled": false,
                  "key": "p",
                  "value": "0",
                  "description": "Result page number (0-based). `p * ps` cannot exceed 10,000."
                },
                {
                  "disabled": false,
                  "key": "ps",
                  "value": "10",
                  "description": "Number of results per page."
                },
                {
                  "disabled": false,
                  "key": "q",
                  "value": "<string>",
                  "description": "Free-text search terms applied across object fields."
                },
                {
                  "disabled": false,
                  "key": "involvedMaker",
                  "value": "<string>",
                  "description": "Restrict to objects produced by this maker (e.g. `Rembrandt van Rijn`)."
                },
                {
                  "disabled": false,
                  "key": "type",
                  "value": "<string>",
                  "description": "Object type (e.g. `schilderij`, `prent`)."
                },
                {
                  "disabled": false,
                  "key": "material",
                  "value": "<string>",
                  "description": "Material used to make the object (e.g. `doek`, `papier`)."
                },
                {
                  "disabled": false,
                  "key": "technique",
                  "value": "<string>",
                  "description": "Technique used to produce the object (e.g. `olieverf`, `ets`)."
                },
                {
                  "disabled": false,
                  "key": "f.dating.period",
                  "value": "<integer>",
                  "description": "Century in which the object was made (0–21)."
                },
                {
                  "disabled": false,
                  "key": "f.normalized32Colors.hex",
                  "value": "<string>",
                  "description": "Filter on the dominant colour palette (32-colour normalised). The\nliteral `#` must be URL-encoded as `%23`.\n"
                },
                {
                  "disabled": false,
                  "key": "imgonly",
                  "value": "false",
                  "description": "Only return objects that have an image."
                },
                {
                  "disabled": false,
                  "key": "toppieces",
                  "value": "false",
                  "description": "Only return objects flagged as top pieces."
                },
                {
                  "disabled": false,
                  "key": "s",
                  "value": "<string>",
                  "description": "Sort order applied to the result set."
                }
              ],
              "variable": [
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<string>",
                  "key": "culture",
                  "description": "(Required) Locale for both the query semantics and the response content (`nl` Dutch, `en` English)."
                }
              ]
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET",
            "auth": null
          },
