{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/rijksmuseum/refs/heads/main/json-structure/rijksmuseum-user-set-summary-structure.json",
  "name": "Rijksstudio User Set Summary",
  "description": "Summary entry returned by GET /{culture}/usersets.",
  "type": "object",
  "x-schema-source": "documentation",
  "x-source-url": "https://data.rijksmuseum.nl/user-generated-content/api/",
  "required": [
    "id",
    "name",
    "slug",
    "count",
    "user"
  ],
  "properties": {
    "links": {
      "type": "object",
      "properties": {
        "self": {
          "type": "uri"
        },
        "web": {
          "type": "uri"
        }
      }
    },
    "id": {
      "type": "string"
    },
    "count": {
      "type": "int32"
    },
    "type": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "slug": {
      "type": "string"
    },
    "description": {
      "type": "string",
      "nullable": true
    },
    "user": {
      "type": "object",
      "properties": {
        "id": {
          "type": "int32"
        },
        "name": {
          "type": "string"
        },
        "lang": {
          "type": "string"
        },
        "avatarUrl": {
          "type": "string",
          "nullable": true
        },
        "headerUrl": {
          "type": "string",
          "nullable": true
        },
        "initials": {
          "type": "string"
        }
      }
    },
    "createdOn": {
      "type": "datetime"
    },
    "updatedOn": {
      "type": "datetime"
    }
  }
}